rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Users collection
    match /users/{userId} {
      // Only the authenticated user can read/write their own profile
      allow read, write: if request.auth != null && request.auth.uid == userId;
    }

    // URLs collection
    match /urls/{urlId} {
      // Anyone can read shortened URLs (for redirection)
      allow read: if true;

      // Only the authenticated creator can create new short URLs
      allow create: if request.auth != null && request.resource.data.userId == request.auth.uid;

      // Only the owner can update/delete their own URLs
      allow update, delete: if request.auth != null && resource.data.userId == request.auth.uid;
    }
  }
}
