rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Users collection
    match /users/{userId} {
      allow read, write: if request.auth != null && request.auth.uid == userId;
    }

    // Short URLs
    match /shortUrls/{shortCode} {
      // Public read for redirection
      allow read: if true;

      // Create: signed in user must own it
      allow create: if request.auth != null
                    && request.resource.data.userId == request.auth.uid;

      // Update/Delete: only owner
      allow update, delete: if request.auth != null
                            && resource.data.userId == request.auth.uid;
    }

    // Unique Visitors
    match /uniqueVisitors/{visitorId} {
      // Allow anyone to create (for anonymous visit tracking)
      allow create: if true;

      // Allow reads only if user is logged in AND owns the related shortUrl
      allow read: if request.auth != null
                  && exists(/databases/$(database)/documents/shortUrls/$(resource.data.shortCode))
                  && get(/databases/$(database)/documents/shortUrls/$(resource.data.shortCode)).data.userId == request.auth.uid;

      // No updates or deletes (optional)
      allow update, delete: if false;
    }

    match /stats/{global} {
      allow read, create, update: if true;
    }
  }
}
