rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Users collection
    match /users/{userId} {
      // Only the authenticated user can read/write their own profile
      allow read, write: if request.auth != null && request.auth.uid == userId;
    }

    // URLs collection
    match /shortUrls/{shortCode} {
          // Anyone can read shortened URLs (for public redirection)
          allow read: if true;

          // Create: must be signed in, and doc must include userId == auth.uid
          allow create: if request.auth != null
                        && request.resource.data.userId == request.auth.uid
                        && request.resource.data.originalUrl is string
                        && request.resource.data.shortCode is string;

          // Update/Delete: only the creator can modify/remove
          allow update, delete: if request.auth != null
                                && resource.data.userId == request.auth.uid;
        }
  }
}
